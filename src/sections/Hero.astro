---
import heroImg from '@/assets/imgs/hero.webp'
---

<section class="relative isolate overflow-hidden text-white bg-brand-deep min-h-[clamp(620px,92vh,880px)]">
  <div
    class="absolute inset-0 z-0 bg-cover bg-[center_30%] animate-hero-zoom"
    style={`background-image: url(${heroImg.src}); filter: saturate(0.95) contrast(1.02);`}
  ></div>
  <div
    class="absolute inset-0 z-[1]"
    style="background: linear-gradient(180deg, rgba(40,24,12,0.10) 0%, rgba(40,24,12,0.25) 40%, rgba(40,24,12,0.80) 100%), linear-gradient(90deg, rgba(40,24,12,0.65) 0%, rgba(40,24,12,0.10) 65%);"
  ></div>
  <div
    class="pointer-events-none absolute inset-0 z-[2] opacity-[0.18] mix-blend-overlay"
    style="background-image: url(&quot;data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)' opacity='0.5'/></svg>&quot;);"
  ></div>

  <div class="relative z-[3] flex flex-col justify-end max-w-[1240px] mx-auto px-[clamp(20px,5vw,64px)] pt-[120px] pb-24 min-h-[clamp(620px,92vh,880px)]">
    <span class="mb-7 inline-flex items-center gap-2.5 text-[12px] font-semibold tracking-[0.18em] uppercase text-accent-soft before:content-[''] before:w-7 before:h-px before:bg-accent-soft before:inline-block">
      Puebla, México · Desde 1999
    </span>
    <h1 class="text-white font-medium max-w-[14ch] mb-7">
      Donde los <em class="not-italic"><span class="italic font-normal text-accent-soft">Campeones</span></em><br />Comienzan
    </h1>
    <p class="max-w-[50ch] text-[clamp(16px,1.4vw,19px)] leading-[1.6] text-white/85 font-light mb-10">
      Adiestramiento profesional especializado en Schnauzer y perros de exposición.
      Educación a domicilio con técnicas de condicionamiento positivo en solo 10 clases.
    </p>
    <div class="flex flex-wrap gap-3.5">
      <a
        href="#services"
        class="inline-flex items-center justify-center gap-2.5 whitespace-nowrap px-[26px] py-[14px] rounded-full text-sm font-semibold tracking-[0.01em] text-white border-[1.5px] border-white/55 bg-white/[0.06] backdrop-blur-sm transition-all duration-200 hover:bg-white/15 hover:border-white hover:-translate-y-px"
      >
        Conoce nuestros planes
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14m-6-6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
      </a>
      <a
        href="https://wa.me/"
        class="inline-flex items-center justify-center gap-2.5 whitespace-nowrap px-[26px] py-[14px] rounded-full text-sm font-semibold tracking-[0.01em] text-white bg-whatsapp shadow-wa transition-all duration-200 hover:bg-whatsapp-deep hover:-translate-y-px"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"></path></svg>
        WhatsApp Directo
      </a>
    </div>
  </div>

  <div class="hidden md:flex absolute right-[clamp(20px,5vw,64px)] bottom-24 z-[3] flex-col gap-7 text-right text-white">
    {[['25+','Años de Experiencia'],['10','Clases por Curso'],['FCI','Certificación Oficial']].map(([n,l]) => (
      <div>
        <div class="font-serif text-[48px] leading-none font-medium text-accent-soft">{n}</div>
        <div class="mt-1.5 text-[11px] tracking-[0.22em] uppercase text-white/70">{l}</div>
      </div>
    ))}
  </div>

  <div class="absolute left-1/2 -translate-x-1/2 bottom-7 z-[3] flex flex-col items-center gap-2 text-white/70 text-[11px] tracking-[0.22em] uppercase">
    <span>Desliza</span>
    <span class="w-px h-9 animate-scroll-pulse" style="background: linear-gradient(180deg, rgba(255,255,255,0.6), transparent);"></span>
  </div>
</section>
