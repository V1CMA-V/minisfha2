---
---

<section id="contact" class="relative overflow-hidden bg-bg py-[clamp(80px,10vw,140px)]">
  <div class="max-w-[1240px] mx-auto px-[clamp(20px,5vw,64px)]">
    <div
      class="relative overflow-hidden rounded-[32px] p-[clamp(48px,6vw,80px)] text-white shadow-hero"
      style="background: linear-gradient(135deg, var(--color-brand-deep) 0%, var(--color-ink) 100%);"
    >
      <span class="absolute -right-[120px] -top-[120px] w-[380px] h-[380px] rounded-full opacity-[0.35] pointer-events-none" style="background: radial-gradient(circle, var(--color-accent) 0%, transparent 65%);"></span>
      <span class="absolute -left-20 -bottom-20 w-60 h-60 rounded-full opacity-25 pointer-events-none" style="background: radial-gradient(circle, var(--color-gold) 0%, transparent 65%);"></span>

      <div class="relative z-[1] grid items-center gap-[clamp(40px,6vw,80px)] grid-cols-1 md:[grid-template-columns:1.1fr_1fr]">
        <div>
          <span class="inline-flex items-center gap-2.5 text-[12px] font-semibold tracking-[0.18em] uppercase text-accent-soft before:content-[''] before:w-7 before:h-px before:bg-accent-soft before:inline-block">
            Hablemos
          </span>
          <h2 class="text-white mt-4 mb-6 max-w-[16ch]">
            Tu próximo <em class="italic font-normal text-accent-soft">campeón</em> empieza con una conversación.
          </h2>
          <p class="text-white/80 text-[17px] leading-[1.6] max-w-[44ch] font-light mb-8">
            Cuéntanos sobre tu perro y la meta que tienes en mente. Te responderemos en menos de 24 horas con una propuesta personalizada.
          </p>

          <div class="flex flex-col gap-3.5">
            <a href="https://wa.me/5212224025619" class="flex items-center gap-4 text-white/90 text-[15px]">
              <span class="grid place-items-center w-10 h-10 rounded-full border" style="background: rgba(37,211,102,0.15); border-color: rgba(37,211,102,0.4);">
                <svg viewBox="0 0 24 24" fill="#25D366" class="w-[18px] h-[18px]"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487 1.21.523 2.155.835 2.892 1.07.121.038.236.057.347.075a3.6 3.6 0 0 0 .647-.044c.45-.067 1.473-.605 1.68-1.188.207-.583.207-1.083.145-1.188-.062-.105-.247-.166-.52-.298"></path></svg>
              </span>
              <div>
                <strong class="block font-semibold text-white text-[13px] tracking-[0.04em]">WhatsApp / Teléfono</strong>
                +52 1 222 402 56 19 — Respuesta inmediata
              </div>
            </a>
            <a href="mailto:minisfha.alvarez@gmail.com" class="flex items-center gap-4 text-white/90 text-[15px]">
              <span class="grid place-items-center w-10 h-10 rounded-full bg-white/[0.08] border border-white/[0.18]">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px]"><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="m3 7 9 6 9-6"></path></svg>
              </span>
              <div>
                <strong class="block font-semibold text-white text-[13px] tracking-[0.04em]">Gmail</strong>
                minisfha.alvarez@gmail.com
              </div>
            </a>
            <a href="https://instagram.com/minisfha" class="flex items-center gap-4 text-white/90 text-[15px]">
              <span class="grid place-items-center w-10 h-10 rounded-full bg-white/[0.08] border border-white/[0.18]">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px]"><rect x="3" y="3" width="18" height="18" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><circle cx="17.5" cy="6.5" r="1" fill="white"></circle></svg>
              </span>
              <div>
                <strong class="block font-semibold text-white text-[13px] tracking-[0.04em]">Instagram</strong>
                @minisfha
              </div>
            </a>
            <a href="https://twitter.com/minisfha" class="flex items-center gap-4 text-white/90 text-[15px]">
              <span class="grid place-items-center w-10 h-10 rounded-full bg-white/[0.08] border border-white/[0.18]">
                <svg viewBox="0 0 24 24" fill="white" class="w-[18px] h-[18px]"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
              </span>
              <div>
                <strong class="block font-semibold text-white text-[13px] tracking-[0.04em]">Twitter / X</strong>
                @minisfha
              </div>
            </a>
            <a href="https://youtube.com/" class="flex items-center gap-4 text-white/90 text-[15px]">
              <span class="grid place-items-center w-10 h-10 rounded-full bg-white/[0.08] border border-white/[0.18]">
                <svg viewBox="0 0 24 24" fill="white" class="w-[18px] h-[18px]"><path d="M23.498 6.186a2.997 2.997 0 0 0-2.11-2.122C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.388.519A2.997 2.997 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a2.997 2.997 0 0 0 2.11 2.122c1.883.519 9.388.519 9.388.519s7.505 0 9.388-.519a2.997 2.997 0 0 0 2.11-2.122C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12z"></path></svg>
              </span>
              <div>
                <strong class="block font-semibold text-white text-[13px] tracking-[0.04em]">YouTube</strong>
                Mini's Fha Alvarez
              </div>
            </a>
            <div class="flex items-center gap-4 text-white/90 text-[15px]">
              <span class="grid place-items-center w-10 h-10 rounded-full bg-white/[0.08] border border-white/[0.18]">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px]"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              </span>
              <div>
                <strong class="block font-semibold text-white text-[13px] tracking-[0.04em]">Ubicación</strong>
                Puebla, México — Atendemos a domicilio
              </div>
            </div>
          </div>
        </div>

        <form class="contact-form bg-white/5 border border-white/[0.12] rounded-card p-[32px_28px] backdrop-blur-sm">
          <h3 class="text-white text-[22px] mb-1.5">Agenda una evaluación</h3>
          <p class="text-white/70 text-[13.5px] mb-6">Sin compromiso. Conoce el plan ideal para tu compañero.</p>

          <div class="mb-3.5">
            <label class="block text-[11px] tracking-[0.14em] uppercase font-semibold text-white/70 mb-2">Tu nombre</label>
            <input type="text" placeholder="María González" required
              class="w-full px-3.5 py-3 bg-white/[0.06] border border-white/[0.15] text-white rounded-lg text-sm placeholder:text-white/40 focus:outline-none focus:border-accent-soft focus:bg-white/10 transition-colors" />
          </div>

          <div class="mb-3.5">
            <label class="block text-[11px] tracking-[0.14em] uppercase font-semibold text-white/70 mb-2">WhatsApp / Teléfono</label>
            <input type="tel" placeholder="+52 222 000 0000" required
              class="w-full px-3.5 py-3 bg-white/[0.06] border border-white/[0.15] text-white rounded-lg text-sm placeholder:text-white/40 focus:outline-none focus:border-accent-soft focus:bg-white/10 transition-colors" />
          </div>

          <div class="mb-3.5">
            <label class="block text-[11px] tracking-[0.14em] uppercase font-semibold text-white/70 mb-2">Raza de tu perro</label>
            <select
              class="w-full px-3.5 py-3 pr-10 bg-white/[0.06] border border-white/[0.15] text-white rounded-lg text-sm appearance-none focus:outline-none focus:border-accent-soft focus:bg-white/10 transition-colors [color-scheme:dark] bg-no-repeat [background-position:right_14px_center]"
              style="background-image: url(&quot;data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8' fill='none'><path d='M1 1.5l5 5 5-5' stroke='rgba(255,255,255,0.6)' stroke-width='1.5' stroke-linecap='round'/></svg>&quot;);"
            >
              <option class="bg-brand-deep text-white">Schnauzer Miniatura</option>
              <option class="bg-brand-deep text-white">Schnauzer Estándar</option>
              <option class="bg-brand-deep text-white">Schnauzer Gigante</option>
              <option class="bg-brand-deep text-white">Otra raza</option>
            </select>
          </div>

          <div class="mb-3.5">
            <label class="block text-[11px] tracking-[0.14em] uppercase font-semibold text-white/70 mb-2">¿Qué buscas trabajar?</label>
            <textarea placeholder="Cuéntanos brevemente sobre el comportamiento o meta…"
              class="w-full px-3.5 py-3 bg-white/[0.06] border border-white/[0.15] text-white rounded-lg text-sm placeholder:text-white/40 focus:outline-none focus:border-accent-soft focus:bg-white/10 transition-colors resize-y min-h-[88px]"></textarea>
          </div>

          <button type="submit"
            class="w-full mt-2.5 py-3.5 rounded-lg bg-accent text-white font-semibold text-sm tracking-[0.02em] transition-colors hover:bg-accent-soft hover:text-brand-deep">
            Solicitar evaluación gratuita
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector('.contact-form') as HTMLFormElement | null
  form?.addEventListener('submit', (e) => {
    e.preventDefault()
    alert('Gracias, te contactamos pronto.')
  })
</script>
