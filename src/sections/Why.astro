---
import whyImg from '@/assets/imgs/why.webp'

const reasons = [
  { title: 'Especialistas en Schnauzer', desc: 'Conocemos a fondo el temperamento, la genética y los retos típicos de la raza. Cada protocolo está hecho a su medida.', icon: `<path d="M12 2l3 6 6 1-4.5 4.5 1 6.5L12 17l-5.5 3 1-6.5L3 9l6-1z"/>` },
  { title: 'Resultados medibles, no promesas', desc: 'Evaluación inicial, plan documentado y reporte clase a clase. Sabrás exactamente lo que mejoró tu perro cada semana.', icon: `<path d="M20 7L9 18l-5-5"/>` },
  { title: 'Avalados por FCI, FCM y aliados', desc: 'Acreditaciones oficiales y participación activa en exposiciones nacionales con jueces internacionales.', icon: `<path d="M12 3l9 4-9 4-9-4 9-4z"/><path d="M3 12l9 4 9-4M3 17l9 4 9-4"/>` },
  { title: 'La familia, parte del proceso', desc: 'Te enseñamos a ti también: claves de manejo, comunicación canina y mantenimiento de los aprendizajes.', icon: `<path d="M3 21c2-5 6-7 9-7s7 2 9 7"/><circle cx="12" cy="7" r="4"/>` },
  { title: 'Resultados en 10 semanas', desc: 'Programa intensivo pero sostenible. Verás cambios desde la segunda sesión y dominio pleno al cierre del curso.', icon: `<circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 2"/>` },
]
---

<section id="why" class="relative bg-bg py-[clamp(80px,10vw,140px)]">
  <div class="max-w-[1240px] mx-auto px-[clamp(20px,5vw,64px)]">
    <div class="grid items-end gap-8 mb-20 grid-cols-1 sm:[grid-template-columns:1fr_auto]">
      <div class="max-w-[600px]">
        <span class="inline-flex items-center gap-2.5 text-[12px] font-semibold tracking-[0.18em] uppercase text-accent before:content-[''] before:w-7 before:h-px before:bg-accent before:inline-block">
          ¿Por qué Minis FHA?
        </span>
        <h2 class="mt-4 max-w-[16ch]">
          Una escuela boutique. Un <em class="italic font-normal text-accent">estándar</em> de campeón.
        </h2>
      </div>
      <p class="max-w-[320px] text-[15px] text-ink-soft leading-[1.6]">
        No somos una academia masiva. Trabajamos pocos perros a la vez para garantizar atención individual y resultados medibles.
      </p>
    </div>

    <div class="grid items-start gap-[clamp(40px,6vw,80px)] grid-cols-1 md:grid-cols-2">
      <div class="grid gap-2">
        {reasons.map((r, i) => (
          <div class={`grid [grid-template-columns:64px_1fr] gap-6 items-start py-7 border-t border-line ${i === reasons.length - 1 ? 'border-b' : ''}`}>
            <div class="grid place-items-center w-14 h-14 rounded-2xl bg-bg-alt text-brand">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7" set:html={r.icon} />
            </div>
            <div>
              <h3 class="text-[22px] mt-1 mb-2 leading-tight">{r.title}</h3>
              <p class="text-[15px] text-ink-soft leading-[1.6]">{r.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <aside class="relative sticky top-[100px] aspect-[4/5] rounded-[32px] overflow-hidden bg-bg-deep shadow-elev">
        <img src={whyImg.src} alt="Schnauzer de exposición" class="w-full h-full object-cover" />
        <div class="absolute inset-x-0 bottom-0 p-[36px_32px_32px] text-white" style="background: linear-gradient(0deg, rgba(30,18,8,0.95) 30%, transparent);">
          <q class="font-serif italic text-[clamp(22px,2.4vw,32px)] leading-[1.25] text-white text-balance">
            El verdadero adiestramiento no doblega — revela el carácter que ya vive en el perro.
          </q>
          <div class="flex items-center gap-3.5 mt-5 text-[13px] text-white/85">
            <span class="w-9 h-px bg-accent-soft"></span>
            <span>Fundadora · Minis FHA, Puebla</span>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>
