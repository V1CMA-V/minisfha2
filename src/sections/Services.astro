---
const services = [
  {
    num: '01 / Conductual',
    title: 'Corrección de Conductas',
    desc: 'Tratamos ladrido excesivo, agresividad, ansiedad por separación y problemas de socialización con un protocolo individualizado.',
    tag: 'A medida',
    icon: `<path d="M3 12c0-4 3-7 6-7s3 4 0 6c-2.5 1.6-3 3.5-3 5"/><circle cx="12" cy="18" r="2"/><path d="M15 7c2 0 4 1 4 4 0 3-3 3-3 5"/>`,
  },
  {
    num: '02 / A domicilio',
    title: 'Cursos a Domicilio',
    desc: 'Entrenamiento en el entorno donde vive tu perro. Adaptamos cada sesión a tu hogar, tu familia y la rutina diaria.',
    tag: 'Puebla y alrededores',
    icon: `<path d="M3 11l9-7 9 7v9a1 1 0 0 1-1 1h-5v-6h-6v6H4a1 1 0 0 1-1-1z"/>`,
  },
  {
    num: '03 / Programa estrella',
    title: 'Solo 10 Clases',
    desc: 'Sesiones de 45 a 60 minutos, una vez por semana. Un programa completo, eficaz y sostenible para tu agenda.',
    tag: '45 – 60 min · 10 sesiones',
    icon: `<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>`,
  },
  {
    num: '04 / Método',
    title: 'Clicker & Halter',
    desc: 'Condicionamiento positivo, sin castigo. Herramientas amables que aceleran el aprendizaje y fortalecen la confianza.',
    tag: 'Refuerzo positivo',
    icon: `<rect x="3" y="9" width="18" height="11" rx="2"/><path d="M8 9V6a4 4 0 0 1 8 0v3"/><circle cx="12" cy="14.5" r="1.4" fill="currentColor"/>`,
  },
]
---

<section id="services" class="relative overflow-hidden bg-bg-alt py-[clamp(80px,10vw,140px)]">
  <div class="max-w-[1240px] mx-auto px-[clamp(20px,5vw,64px)]">
    <div class="grid items-end gap-8 mb-16 grid-cols-1 sm:[grid-template-columns:1fr_auto]">
      <div class="max-w-[600px]">
        <span class="inline-flex items-center gap-2.5 text-[12px] font-semibold tracking-[0.18em] uppercase text-accent before:content-[''] before:w-7 before:h-px before:bg-accent before:inline-block">
          Nuestros Servicios
        </span>
        <h2 class="mt-4 max-w-[16ch]">
          Planes diseñados para <em class="italic font-normal text-accent">cada etapa</em> de tu compañero.
        </h2>
      </div>
      <p class="max-w-[320px] text-[15px] text-ink-soft leading-[1.6]">
        Programas estructurados, evaluados clase a clase. Desde la corrección de conductas hasta la preparación para el ring de exposición.
      </p>
    </div>

    <div class="grid gap-[22px] grid-cols-1 sm:grid-cols-2 xl:grid-cols-4">
      {services.map((s) => (
        <article class="group relative flex flex-col min-h-[340px] p-[36px_30px_32px] bg-bg rounded-card border border-line/60 shadow-soft transition-all duration-300 hover:-translate-y-1.5 hover:shadow-elev hover:border-accent-soft">
          <div class="font-serif italic text-sm text-muted tracking-[0.04em] mb-6">{s.num}</div>
          <div class="grid place-items-center w-14 h-14 rounded-full bg-bg-alt text-brand mb-6 transition-colors duration-300 group-hover:bg-brand-deep group-hover:text-bg">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7" set:html={s.icon} />
          </div>
          <h3 class="text-2xl mb-3 leading-tight text-balance">{s.title}</h3>
          <p class="flex-1 text-[14.5px] text-ink-soft leading-[1.6] mb-6">{s.desc}</p>
          <div class="pt-[18px] border-t border-line text-[11px] tracking-[0.16em] uppercase font-semibold text-accent">{s.tag}</div>
        </article>
      ))}
    </div>
  </div>
</section>
