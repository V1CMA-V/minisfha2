---
---

<nav class="sticky top-0 z-[100] bg-bg/85 backdrop-blur-md backdrop-saturate-150 border-b border-line/60">
  <div class="flex items-center justify-between h-[78px] max-w-[1240px] mx-auto px-[clamp(20px,5vw,64px)]">
    <a href="#" class="flex items-center gap-3">
      <div class="grid place-items-center w-11 h-11 rounded-full bg-brand-deep text-bg font-serif italic font-semibold text-[22px] -tracking-[0.04em] shadow-mark">
        <span class="-translate-y-px">M</span>
      </div>
      <div class="flex flex-col leading-none">
        <div class="font-serif text-[22px] font-semibold tracking-[0.02em] text-ink">Minis FHA</div>
        <div class="mt-1 text-[10px] font-semibold tracking-[0.22em] uppercase text-muted">Adiestramiento Canino</div>
      </div>
    </a>

    <ul class="hidden md:flex gap-9 list-none p-0 m-0">
      {[
        ['#about', 'Nosotros'],
        ['#services', 'Servicios'],
        ['#why', 'Por qué'],
        ['#certifications', 'Certificaciones'],
        ['#contact', 'Contacto'],
      ].map(([href, label]) => (
        <li>
          <a
            href={href}
            class="relative text-sm font-medium text-ink-soft transition-colors hover:text-brand after:content-[''] after:absolute after:left-0 after:right-0 after:-bottom-1.5 after:h-[1.5px] after:bg-accent after:scale-x-0 after:origin-left after:transition-transform after:duration-300 hover:after:scale-x-100"
          >{label}</a>
        </li>
      ))}
    </ul>

    <a
      href="#contact"
      class="inline-flex items-center justify-center gap-2.5 whitespace-nowrap px-[26px] py-[14px] rounded-full bg-brand-deep text-bg text-sm font-semibold tracking-[0.01em] shadow-card transition-all duration-200 hover:bg-ink hover:-translate-y-px hover:shadow-elev"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14m-6-6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
      Agenda tu clase
    </a>
  </div>
</nav>
